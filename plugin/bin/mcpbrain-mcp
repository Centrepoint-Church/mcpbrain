#!/bin/sh
# PATH-proof shim: locate the installed mcpbrain daemon binary and exec
# `mcpbrain mcp-server`. Resolution: PATH → ~/.local/bin → uv tool dir.
set -eu
_find() {
  if command -v mcpbrain >/dev/null 2>&1; then command -v mcpbrain; return; fi
  if [ -x "$HOME/.local/bin/mcpbrain" ]; then echo "$HOME/.local/bin/mcpbrain"; return; fi
  if command -v uv >/dev/null 2>&1; then
    b="$(uv tool dir 2>/dev/null)/bin/mcpbrain"; [ -x "$b" ] && { echo "$b"; return; }
  fi
  return 1
}
BIN="$(_find)" || { echo "mcpbrain: binary not found. Run the install skill in Cowork." >&2; exit 1; }
# Honour an explicitly-set MCPBRAIN_HOME; otherwise leave it unset so mcpbrain
# resolves its own platform-default home — the same one `mcpbrain setup` registers
# the daemon with (~/Library/Application Support/mcpbrain on macOS). Forcing a
# ~/.mcpbrain default here pointed the MCP server at an empty store on macOS.
if [ -n "${MCPBRAIN_HOME:-}" ]; then export MCPBRAIN_HOME; fi
exec "$BIN" mcp-server "$@"
